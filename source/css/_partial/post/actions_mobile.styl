#footer-post
  position: fixed
  right: 0
  bottom: 0
  left: 0
  z-index: 5000000
  width: 100%
  border-top: 1px solid $color-border
  background: $color-footer-mobile-1
  transition: opacity .2s

  a
    background: none
    color: inherit
    text-decoration: none

  a.icon
    background: none

    &:hover
      color: $color-link

  #nav-footer
    padding-right: 1rem
    padding-left: 1rem
    background: $color-footer-mobile-2
    text-align: center

    a
      color: $color-accent-1
      font-size: 1em

    a:hover
      underline(5px, $color-accent-1)

    ul
      display: table
      margin: 0
      padding: 0
      width: 100%
      list-style-type: none

      li
        display: inline-table
        padding: 10px
        width: 20%
        vertical-align: middle

  #actions-footer
    overflow: auto
    margin-top: 1rem
    margin-bottom: 1rem
    padding-right: 1rem
    padding-left: 1rem
    width: 100%
    text-align: center
    white-space: nowrap

    a
      display: inline-block
      padding-left: 1rem
      color: $color-accent-1

  #share-footer
    padding-right: 1rem
    padding-left: 1rem
    background: $color-footer-mobile-2
    text-align: center

    ul
      display: table
      margin: 0
      padding: 0
      width: 100%
      list-style-type: none

      li
        display: inline-table
        padding: 10px
        width: 20%
        vertical-align: middle

  #toc-footer
    clear: both
    padding-top: 1rem
    padding-bottom: 1rem
    background: $color-footer-mobile-2
    text-align: left
    
    .toc-title
      margin-bottom: .75rem
      padding: 0 1rem
      color: $color-text
      font-size: .95rem
      font-weight: 700

    ol
      margin: 0
      padding: 0 1rem 0 1.25rem
      list-style-type: none

      li
        line-height: 1.7

    a:hover
      color: $color-link

    .toc-link
      display: inline-block

    .toc-level-1
      color: $color-text
      font-size: .9rem
      font-weight: 600

      &:before
        color: $color-accent-1
        content: "#"
        margin-right: .35rem

    .toc-level-2
      color: $color-meta
      margin-left: .8rem
      font-size: .82rem

    .toc-level-3
      color: darken($color-meta, 5%)
      margin-left: 1.4rem
      font-size: .76rem

    .toc-level-4
      color: darken($color-meta, 15%)
      margin-left: 2rem
      font-size: .72rem

    .toc-level-5
      display: none

    .toc-level-6
      display: none

    .toc-number
      margin-right: .3rem
      color: $color-accent-1
      font-size: .8em

@media screen and (min-width: 500px)
  #footer-post-container
    display: none
