#friends-page
  .friend-grid
    display: grid
    grid-template-columns: repeat(auto-fill, minmax(var(--friends-card-min-width, 160px), 1fr))
    gap: var(--friends-grid-gap, 20px)
    margin-top: 2rem

  .friend-card
    display: flex
    flex-direction: column
    align-items: center
    justify-content: center
    gap: var(--friends-content-gap, 14px)
    min-height: var(--friends-card-min-height, 170px)
    padding: 1.5rem 1rem
    border: 1px solid $color-border
    border-radius: 18px
    background: rgba($color-background, .6)
    text-align: center
    transition: transform .18s ease, border-color .18s ease, box-shadow .18s ease
    box-shadow: 0 8px 24px rgba(0, 0, 0, .08)
    text-decoration: none

    &:hover
      transform: translateY(-4px)
      border-color: $color-link
      box-shadow: 0 14px 28px rgba(0, 0, 0, .12)
      background: rgba($color-background, .9)

  .friend-card.is-disabled
    cursor: default

    &:hover
      transform: none
      border-color: $color-border

  .friend-avatar
    display: flex
    align-items: center
    justify-content: center
    width: var(--friends-avatar-size, 76px)
    height: var(--friends-avatar-size, 76px)
    border: 1px solid $color-border
    border-radius: 50%
    background: $color-background-code
    overflow: hidden
    font-size: 1.1rem
    font-weight: 700
    letter-spacing: .04em

    img
      width: 100%
      height: 100%
      object-fit: cover

  .friend-name
    display: block
    max-width: 100%
    color: $color-text
    font-size: 1rem
    font-weight: 600
    line-height: 1.4
    word-break: break-word
