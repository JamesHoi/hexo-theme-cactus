.pdf-embed
  margin: 1.5rem 0
  width: 100%
  border: 1px solid $color-border
  border-radius: 10px
  overflow: hidden
  background: $color-background-code

  .pdf-embed-frame
    display: block
    width: 100%
    min-height: 640px
    border: 0
    background: #fff

.pdf-embed-error
  padding: 1rem 1.2rem
  color: $color-text
